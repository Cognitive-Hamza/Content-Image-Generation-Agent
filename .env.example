# Runtime environment: dev | staging | prod
# AUTH_MODE=dev is only permitted when ENV=dev — the app refuses to boot otherwise.
ENV=dev

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://cig:cig@localhost:5432/cig

# ── Auth (mechanism owned by SysOps — this app only implements the abstraction) ─
# AUTH_MODE=header expects an identity header set by an upstream proxy
#   (e.g. oauth2-proxy's X-Auth-Request-Email, or an ALB+OIDC equivalent).
# AUTH_MODE=jwt expects a `Authorization: Bearer <jwt>` with an email claim.
# AUTH_MODE=dev is for local development only.
AUTH_MODE=dev
AUTH_HEADER_NAME=X-Auth-Request-Email
AUTH_JWT_SECRET=
AUTH_JWT_JWKS_URL=
AUTH_JWT_EMAIL_CLAIM=email
DEV_USER_EMAIL=dev@alnafi.local

# ── Session (one-shot flash messages only — see app/main.py) ────────────────
SESSION_SECRET_KEY=change-me-to-a-random-value-in-every-real-deployment

# ── Storage backend (vendor owned by SysOps — this app only implements the abstraction) ─
# STORAGE_BACKEND=local writes under STORAGE_LOCAL_ROOT and serves via /media/{key}.
# STORAGE_BACKEND=s3 requires S3_BUCKET; S3_ENDPOINT_URL may point at MinIO for local testing.
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./data/storage
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=

# ── Content/image generation API keys (unchanged from the Streamlit app) ────
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── One-off SQLite -> Postgres migration (scripts/migrate_sqlite_to_postgres.py) ─
ALNAFI_DB_PATH=./data/alnafi_pipeline.db
MIGRATION_FALLBACK_USER_EMAIL=migration@alnafi.local
